  .progress-bar-lg { height: 6px; border-radius: 3px; background: var(--border); margin: .5rem 0 1.25rem; }
  .progress-bar-lg .fill { height: 100%; border-radius: 3px; background: var(--text); transition: width .3s; }
  .progress-summary { font-size: 13px; color: var(--muted); margin-bottom: 1rem; }
  .progress-summary strong { color: var(--text); }

  /* ── Buttons ── */
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: .5rem 1rem; border-radius: 7px;
