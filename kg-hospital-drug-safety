  .tag-rdf    { background: var(--blue-bg);   color: var(--blue-dk); }
  .tag-owl    { background: var(--red-bg);    color: var(--red-dk); }
  .tag-onto   { background: var(--amber-bg);  color: var(--amber-dk); }
  .tag-sparql { background: var(--purple-bg); color: var(--purple-dk); }
  .tag-demo   { background: var(--green-bg);  color: var(--green-dk); }
  .tag-concept{ background: #f1efe8; color: var(--muted); }

  /* ── Triples display ── */
  .triple-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin: 6px 0; }
  .t-s { background: var(--blue-bg);   color: var(--blue-dk);   padding: 3px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }
  .t-p { background: var(--amber-bg);  color: var(--amber-dk);  padding: 3px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }
  .t-o { background: var(--green-bg);  color: var(--green-dk);  padding: 3px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }
  .t-arr { color: var(--faint); font-size: 16px; }
  .t-note { font-size: 11px; color: var(--faint); }

  /* ── Code blocks ── */
