  /* ── Alerts ── */
  .alert { border-radius: 8px; padding: .75rem 1rem; font-size: 13px; line-height: 1.6; margin: .75rem 0; }
  .alert-info    { background: var(--blue-bg);   color: var(--blue-dk);   border-left: 3px solid var(--blue); }
  .alert-success { background: var(--green-bg);  color: var(--green-dk);  border-left: 3px solid var(--green); }
