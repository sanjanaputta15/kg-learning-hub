  .section-head .sh-chevron { font-size: 12px; color: var(--faint); transition: transform .2s; }
  .section-head.open .sh-chevron { transform: rotate(90deg); }
  .section-items { border: 1px solid var(--border); border-top: none; border-radius: 0 0 8px 8px; overflow: hidden; }

  .topic-row {
    display: flex; align-items: flex-start; gap: 10px;
